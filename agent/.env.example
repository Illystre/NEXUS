# ── NEXUS Agent Configuration ─────────────────────────────────────────────────
# Copy this file to .env and fill in your values

# NEXUS server URL (required)
NEXUS_URL=http://YOUR_NEXUS_IP:9090

# Agent token generated from NEXUS Settings → Hosts (required)
NEXUS_AGENT_TOKEN=YOUR_TOKEN_HERE

# ── Docker connection — choose your OS ────────────────────────────────────────

# Linux / macOS (default):
DOCKER_SOCKET=/var/run/docker.sock
DOCKER_HOST=

# Windows (Docker Desktop):
# 1. In Docker Desktop → Settings → General → enable "Expose daemon on tcp://localhost:2375 without TLS"
# 2. Replace the two lines above with:
# DOCKER_SOCKET=//./pipe/docker_engine
# DOCKER_HOST=tcp://host.docker.internal:2375
